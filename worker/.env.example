# Copy to .env and fill in. .env is gitignored — never commit real values.

# Neon Postgres (with PostGIS). Get from https://neon.tech (free tier).
# After creating the project, run once in the SQL editor: CREATE EXTENSION postgis;
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Source API keys (all free tiers). Leave blank to disable that source.
# Ticketmaster Discovery: https://developer.ticketmaster.com (free key)
TICKETMASTER_API_KEY=
# SeatGeek Platform: https://platform.seatgeek.com (free client id; secret optional)
SEATGEEK_CLIENT_ID=
SEATGEEK_CLIENT_SECRET=
# Eventbrite: private OAuth token. Search is org-scoped now, so this pulls the
# token account's own live events. Optionally pin one org id.
EVENTBRITE_TOKEN=
EVENTBRITE_ORG_ID=

# Scrapers (Funcheap, Luma) need no keys. Set a contact User-Agent for fair use.
SCRAPER_USER_AGENT=sf-eventmap (your-email@example.com)

# Geocoding (Nominatim fair-use requires a contact string in the User-Agent).
NOMINATIM_USER_AGENT=sf-eventmap (your-email@example.com)
